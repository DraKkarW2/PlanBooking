{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build mysql cpp",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/models/plane.cpp",
                "${workspaceFolder}/models/sqlconnect.cpp",
                "${workspaceFolder}/models/passengers.cpp",
                "-IC:/msys64/ucrt64/include",
                "-LC:/msys64/ucrt64/lib",
                "-lmariadb",
                "-o",
                "${workspaceFolder}/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}